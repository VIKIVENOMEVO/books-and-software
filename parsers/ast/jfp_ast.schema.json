{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JFP Canonical Abstract Syntax Tree",
  "description": "Canonical AST format for all JFP parsers. All parsers must produce output conforming to this schema.",
  "type": "object",
  "required": ["version", "type", "meta", "sections"],
  "properties": {
    "version": {
      "type": "string",
      "description": "JFP protocol version (e.g., '13.0.0')",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "type": {
      "type": "string",
      "description": "Document type",
      "enum": ["BUILD_SPEC", "PATCH_SPEC", "AGENT_TASK_PACKET", "DECISION_RECORD", "CONVERSATION_COMPRESSION"]
    },
    "meta": {
      "type": "object",
      "description": "Document metadata",
      "required": ["timestamp"],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Document creation timestamp (ISO 8601)"
        },
        "author": {
          "type": "string",
          "description": "Document author"
        },
        "title": {
          "type": "string",
          "description": "Document title"
        },
        "description": {
          "type": "string",
          "description": "Document description"
        }
      }
    },
    "sections": {
      "type": "object",
      "description": "JFP document sections",
      "properties": {
        "META": {
          "type": "array",
          "description": "Metadata section entries",
          "items": {"type": "object"}
        },
        "BUILD_GRAPH": {
          "type": "array",
          "description": "Build graph section entries (tasks)",
          "items": {
            "type": "object",
            "properties": {
              "task_id": {"type": "string"},
              "description": {"type": "string"},
              "type": {"type": "string"}
            }
          }
        },
        "OUTPUT_MAP": {
          "type": "array",
          "description": "Expected outputs and acceptance criteria",
          "items": {"type": "object"}
        },
        "CONSTRAINTS": {
          "type": "array",
          "description": "Safety rules and constraints",
          "items": {"type": "object"}
        },
        "ACCEPTANCE": {
          "type": "array",
          "description": "Proof and acceptance criteria",
          "items": {"type": "object"}
        }
      }
    },
    "tasks": {
      "type": "array",
      "description": "Parsed tasks",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "type": {"type": "string"},
          "dependencies": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "description": "Task dependencies",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": {"type": "string"},
          "to": {"type": "string"},
          "type": {"type": "string"}
        }
      }
    },
    "constraints": {
      "type": "array",
      "description": "Parsed constraints",
      "items": {
        "type": "object",
        "required": ["id", "rule"],
        "properties": {
          "id": {"type": "string"},
          "rule": {"type": "string"},
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          }
        }
      }
    },
    "proof_chain": {
      "type": "array",
      "description": "Proof and verification chain",
      "items": {"type": "object"}
    },
    "errors": {
      "type": "array",
      "description": "Parsing or validation errors",
      "items": {
        "type": "object",
        "properties": {
          "line": {"type": "integer"},
          "column": {"type": "integer"},
          "message": {"type": "string"},
          "severity": {
            "type": "string",
            "enum": ["error", "warning"]
          }
        }
      }
    }
  }
}
